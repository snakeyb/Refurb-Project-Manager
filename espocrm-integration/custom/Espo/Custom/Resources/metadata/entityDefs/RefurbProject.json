{
  "fields": {
    "name": {
      "type": "varchar",
      "required": true,
      "maxLength": 255
    },
    "status": {
      "type": "enum",
      "options": ["Draft", "Approved", "In Progress", "Completed", "Cancelled"],
      "default": "Draft",
      "style": {
        "Draft": "default",
        "Approved": "primary",
        "In Progress": "warning",
        "Completed": "success",
        "Cancelled": "danger"
      }
    },
    "description": {
      "type": "text"
    },
    "currency": {
      "type": "varchar",
      "maxLength": 3,
      "default": "GBP"
    },
    "associatedEntityType": {
      "type": "varchar",
      "maxLength": 100
    },
    "associatedEntityId": {
      "type": "varchar",
      "maxLength": 36
    },
    "associatedEntityName": {
      "type": "varchar",
      "maxLength": 255
    },
    "lineItems": {
      "type": "text",
      "view": "views/fields/text"
    },
    "subtotal": {
      "type": "float",
      "default": 0
    },
    "vatTotal": {
      "type": "float",
      "default": 0
    },
    "grandTotal": {
      "type": "float",
      "default": 0
    },
    "notes": {
      "type": "text"
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    }
  },
  "links": {},
  "collection": {
    "orderBy": "createdAt",
    "order": "desc",
    "textFilterFields": ["name", "description"]
  }
}
